#r "nuget: ScottPlot, 5.0.21"
#r "task14/bin/Debug/net10.0/task14.dll"

using System;
using System.Diagnostics;
using System.IO;
using System.Linq;
using ScottPlot;
using task14;

public static class SequentialIntegral
{
    public static double SolveSequential(double a, double b, Func<double, double> function, double step)
    {
        double sum = 0.0;
        double currentX = a;
        while (currentX < b)
        {
            double nextX = Math.Min(currentX + step, b);
            sum += (function(currentX) + function(nextX)) * (nextX - currentX) / 2.0;
            currentX = nextX;
        }
        return sum;
    }
}

double a = -100, b = 100;
Func<double, double> sinFunc = Math.Sin;
double targetAccuracy = 1e-4;

double selectedStep = 1e-6; 

int iterations = 5;
int[] threadConfigs = new int[] { 1, 2, 4, 8, 16 };

var avgTimes = threadConfigs.Select(threads =>
{
    var sw = new Stopwatch();
    DefiniteIntegral.Solve(a, b, sinFunc, selectedStep, threads);
    
    sw.Start();
    Enumerable.Range(0, iterations).ToList().ForEach(_ => DefiniteIntegral.Solve(a, b, sinFunc, selectedStep, threads));
    sw.Stop();
    
    return (double)sw.ElapsedMilliseconds / iterations;
}).ToArray();

var seqSw = new Stopwatch();
seqSw.Start();
Enumerable.Range(0, iterations).ToList().ForEach(_ => SequentialIntegral.SolveSequential(a, b, sinFunc, selectedStep));
seqSw.Stop();
double seqAvgTime = (double)seqSw.ElapsedMilliseconds / iterations;

double optimalMultiTime = avgTimes.Min();
int optimalThreads = threadConfigs[Array.IndexOf(avgTimes, optimalMultiTime)];
double efficiencyGain = ((seqAvgTime - optimalMultiTime) / seqAvgTime) * 100;

string logText = $@"Результаты исследования эффективности многопоточности:
Минимальный размер шага (п.3): {selectedStep}
Оптимальное количество потоков (п.4): {optimalThreads}
Среднее время работы чистой однопоточной версии: {seqAvgTime:F2} мс
Среднее время работы оптимальной многопоточной версии: {optimalMultiTime:F2} мс
Прирост производительности многопоточной версии: {efficiencyGain:F2}% (Требование ТЗ: не менее 15%)";

File.WriteAllText("task15_results.txt", logText);
Console.WriteLine(logText);

var plt = new ScottPlot.Plot();
plt.Add.Scatter(threadConfigs.Select(t => (double)t).ToArray(), avgTimes);
plt.Title("Зависимость производительности от числа потоков");
plt.XLabel("Количество потоков");
plt.YLabel("Время выполнения (мс)");
plt.SavePng("task15_chart.png", 600, 400);
